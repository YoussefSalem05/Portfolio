// ================================================================
// MDPS374 - Control Room Environmental Monitoring & Alarm System
// ESP32-WROOM-32 | PlatformIO | VSCode
// ----------------------------------------------------------------
// LCD SDA    : GPIO21
// LCD SCL    : GPIO22
// DHT22      : GPIO32
// Buzzer Relay : GPIO17
// LED Relay  : GPIO18
// Keypad Rows: GPIO13, GPIO12, GPIO14, GPIO27
// Keypad Cols: GPIO26, GPIO25, GPIO33, GPIO15
// ================================================================

#include <Arduino.h>
#include <Wire.h>
#include <LiquidCrystal_I2C.h>
#include <Keypad.h>
#include <DHT.h>

// --- LCD ---
LiquidCrystal_I2C lcd(0x27, 16, 2);

// --- DHT22 ---
#define DHTPIN  32
#define DHTTYPE DHT22
DHT dht(DHTPIN, DHTTYPE);

// --- Keypad ---
const byte ROWS = 4;
const byte COLS = 4;
char keys[ROWS][COLS] = {
  {'1','2','3','A'},
  {'4','5','6','B'},
  {'7','8','9','C'},
  {'*','0','#','D'}
};
byte rowPins[ROWS] = {13, 12, 14, 27};
byte colPins[COLS] = {26, 25, 33, 15};
Keypad keypad = Keypad(makeKeymap(keys), rowPins, colPins, ROWS, COLS);

// --- Outputs ---
const int buzzRelay = 17;
const int ledRelay  = 18;

// --- Filter Variables ---
// y(n) = α * x(n) + (1 - α) * y(n-1)
const float alpha  = 0.7;
float filteredTemp = 0.0;
float filteredHum  = 0.0;
bool  firstRun     = true;

// --- Setpoints ---
float tempSetPoint = 27.0;
float humSetPoint  = 80.0;

// --- State Variables ---
String inputBuffer  = "";
char   currentMode  = ' ';
bool   isProgramming = false;
unsigned long lastUpdate = 0;

// ================================================================
void setup() {
  Serial.begin(115200);
  delay(500);

  Wire.begin(21, 22);
  delay(500);

  lcd.init();
  lcd.backlight();
  dht.begin();

  pinMode(buzzRelay, OUTPUT);
  pinMode(ledRelay,  OUTPUT);

  digitalWrite(buzzRelay, LOW);
  digitalWrite(ledRelay,  LOW);

  lcd.setCursor(0, 0);
  lcd.print("Control Room Mon");
  lcd.setCursor(0, 1);
  lcd.print("Initializing... ");
  delay(2000);
  lcd.clear();

  Serial.println("System Started.");
}

// ================================================================
void loop() {

  // ── 1. Keypad Logic ───────────────────────────────────────────
  char key = keypad.getKey();
  if (key) {
    Serial.print("Key: "); Serial.println(key);

    if (key == 'C') {
      isProgramming = true;
      currentMode   = 'T';
      inputBuffer   = "";
      lcd.clear();
      lcd.setCursor(0, 0);
      lcd.print("Set Temp Limit:");

    } else if (key == 'A') {
      isProgramming = true;
      currentMode   = 'H';
      inputBuffer   = "";
      lcd.clear();
      lcd.setCursor(0, 0);
      lcd.print("Set Hum Limit: ");

    } else if (isProgramming && key >= '0' && key <= '9') {
      inputBuffer += key;
      lcd.setCursor(0, 1);
      lcd.print(inputBuffer);

    } else if (isProgramming && key == 'B') {
      if (inputBuffer.length() > 0) {
        if (currentMode == 'T') {
          tempSetPoint = inputBuffer.toFloat();
          Serial.print("New Tset: "); Serial.println(tempSetPoint);
        }
        if (currentMode == 'H') {
          humSetPoint = inputBuffer.toFloat();
          Serial.print("New Hset: "); Serial.println(humSetPoint);
        }
      }
      isProgramming = false;
      lcd.clear();
    }
  }

  // ── 2. Sensor + Alarm Logic (every 2 seconds) ─────────────────
  if (millis() - lastUpdate > 2000) {
    lastUpdate = millis();

    float rawT = dht.readTemperature();
    float rawH = dht.readHumidity();

    if (!isnan(rawT) && !isnan(rawH)) {

      // Digital Low-Pass Filter (EMA)
      if (firstRun) {
        filteredTemp = rawT;
        filteredHum  = rawH;
        firstRun     = false;
      } else {
        filteredTemp = (alpha * rawT) + ((1.0 - alpha) * filteredTemp);
        filteredHum  = (alpha * rawH) + ((1.0 - alpha) * filteredHum);
      }

      // Serial debug
      Serial.print("Raw->  T: "); Serial.print(rawT);
      Serial.print("C  H: ");     Serial.print(rawH);
      Serial.println("%");
      Serial.print("Filt-> T: "); Serial.print(filteredTemp);
      Serial.print("C  H: ");     Serial.print(filteredHum);
      Serial.println("%");
      Serial.println("--------------");

      if (!isProgramming) {

        // Line 1: Live readings
        lcd.setCursor(0, 0);
        lcd.print("T:");
        lcd.print(filteredTemp, 1);
        lcd.print("C H:");
        lcd.print(filteredHum, 1);
        lcd.print("%  ");

        // Alarm logic
        bool tAlarm = (filteredTemp >= tempSetPoint);
        bool hAlarm = (filteredHum  >= humSetPoint);

        digitalWrite(buzzRelay, (tAlarm || hAlarm) ? HIGH : LOW);
        digitalWrite(ledRelay, (tAlarm || hAlarm) ? HIGH : LOW);


        // Line 2: Status
        lcd.setCursor(0, 1);
        if      (tAlarm && hAlarm) lcd.print("!! DUAL ALARM !!");
        else if (tAlarm)           lcd.print("!! TEMP ALARM !!");
        else if (hAlarm)           lcd.print("!! HUM  ALARM !!");
        else {
          lcd.print("T:");
          lcd.print((int)tempSetPoint);
          lcd.print(" H:");
          lcd.print((int)humSetPoint);
          lcd.print("%      ");
        }
      }

    } else {
      Serial.println("DHT22 read failed!");
      lcd.setCursor(0, 1);
      lcd.print("DHT Error!      ");
    }
  }
}
